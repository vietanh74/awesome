{
  "name": "awesome",
  "private": true,
  "version": "0.0.0",
  "homepage": "https://vietanh74.github.io/awesome",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "types-check": "vue-tsc --noEmit",
    "lint:partOfScript": "eslint -c eslint.config.mjs --quiet",
    "lint:script": "npm run lint:partOfScript --",
    "lint:partOfPrettier": "prettier --ignore-path .gitignore",
    "lint:prettier": "npm run lint:partOfPrettier -- \"src/**/*+(js|cjs|ts|vue|scss)\"",
    "lint:partOfStyle": "stylelint --allow-empty-input -i .gitignore -i .stylelintignore",
    "lint:style": "npm run lint:partOfStyle -- src/**/*.{css,scss}",
    "lint": "npm run lint:style && npm run lint:prettier -- --check && npm run lint:script",
    "lintfix": "npm run lint:style -- --fix && npm run lint:prettier -- --write && npm run lint:script -- --fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@ant-design/icons-vue": "^7.0.1",
    "@vueuse/core": "^14.2.1",
    "ant-design-vue": "^4.2.6",
    "axios": "^1.14.0",
    "date-chinese": "^2.1.4",
    "date-fns": "^4.1.0",
    "gh-pages": "^6.3.0",
    "lodash-es": "^4.17.23",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.2.2",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.19.15",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-prettier": "^10.2.0",
    "eslint": "^10.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.8",
    "postcss-html": "^1.8.0",
    "prettier": "^3.5.1",
    "rollup-plugin-copy": "^3.5.0",
    "sass": "^1.98.0",
    "stylelint": "^17.6.0",
    "stylelint-config-prettier-scss": "^1.0.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.3",
    "vite-svg-loader": "^5.1.1",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6"
  },
  "volta": {
    "node": "22.19.0"
  },
  "lint-staged": {
    "*.{js,cjs,ts,vue}": [
      "npm run lint:partOfScript"
    ],
    "*.{js,cjs,ts,vue,css,scss}": [
      "npm run lint:partOfPrettier -- --check"
    ],
    "*.{css,scss}": [
      "npm run lint:partOfStyle"
    ]
  }
}
